# Makefile for elfdos-sys (host-side installer)
# Tested with GCC on Linux and MinGW on Windows.

CC      = gcc
CFLAGS  = -std=c99 -Wall -Wextra -O2

# Output name differs by platform
ifeq ($(OS),Windows_NT)
    TARGET = elfdos-sys.exe
else
    TARGET = elfdos-sys
endif

.PHONY: all clean

all: $(TARGET)

$(TARGET): sys.c
	$(CC) $(CFLAGS) -o $@ $<

clean:
	rm -f $(TARGET)
